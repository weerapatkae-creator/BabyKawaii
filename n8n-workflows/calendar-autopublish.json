{
  "name": "BabyKawaii — Calendar Auto Publish",
  "nodes": [
    {
      "id": "cron-trigger",
      "name": "Every Minute Check",
      "type": "n8n-nodes-base.cron",
      "typeVersion": 1,
      "position": [100, 300],
      "parameters": {
        "triggerTimes": {
          "item": [{ "mode": "everyMinute" }]
        }
      }
    },
    {
      "id": "get-scheduled",
      "name": "Get Scheduled Posts",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 3,
      "position": [320, 300],
      "parameters": {
        "method": "GET",
        "url": "={{$env.BABYKAWAII_URL}}/api/calendar-get-scheduled.php",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "headers": {
          "parameters": [
            { "name": "X-API-Key", "value": "={{$env.BABYKAWAII_API_KEY}}" }
          ]
        },
        "options": { "response": { "response": { "responseFormat": "json" } } }
      }
    },
    {
      "id": "check-has-posts",
      "name": "Has Posts?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [540, 300],
      "parameters": {
        "conditions": {
          "number": [
            {
              "value1": "={{ $json.count }}",
              "operation": "larger",
              "value2": 0
            }
          ]
        }
      }
    },
    {
      "id": "split-posts",
      "name": "Split Each Post",
      "type": "n8n-nodes-base.splitInBatches",
      "typeVersion": 2,
      "position": [760, 200],
      "parameters": {
        "batchSize": 1,
        "options": {}
      }
    },
    {
      "id": "split-platforms",
      "name": "Split Each Platform",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [980, 200],
      "parameters": {
        "jsCode": "const post = $input.first().json;\nconst platforms = post.platforms || [];\nreturn platforms.map(pf => ({\n  json: {\n    post_id: post.post_id,\n    title: post.title,\n    post_type: post.post_type,\n    caption: pf.caption,\n    hashtags: pf.hashtags,\n    media: post.media,\n    platform_id: pf.platform_id,\n    platform_name: pf.platform_name,\n    platform_type: pf.platform_type,\n    product: post.product,\n    promotion: post.promotion,\n    callback_url: post.callback_url,\n    api_key: post.api_key\n  }\n}));"
      }
    },
    {
      "id": "route-platform",
      "name": "Route by Platform",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 2,
      "position": [1200, 200],
      "parameters": {
        "mode": "expression",
        "output": "={{ $json.platform_type.toLowerCase() }}",
        "rules": {
          "rules": [
            { "value": "facebook", "outputKey": "facebook" },
            { "value": "instagram", "outputKey": "instagram" },
            { "value": "tiktok", "outputKey": "tiktok" },
            { "value": "line", "outputKey": "line" }
          ]
        },
        "options": { "fallbackOutput": "none" }
      }
    },
    {
      "id": "publish-facebook",
      "name": "Publish to Facebook",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 3,
      "position": [1440, 100],
      "parameters": {
        "method": "POST",
        "url": "=https://graph.facebook.com/v18.0/{{$env.FB_PAGE_ID}}/photos",
        "body": {
          "parameters": [
            { "name": "access_token", "value": "={{$env.FB_PAGE_TOKEN}}" },
            { "name": "message", "value": "={{ $json.caption }}" },
            { "name": "url", "value": "={{ $json.media[0]?.url || '' }}" }
          ]
        },
        "options": {}
      }
    },
    {
      "id": "publish-instagram",
      "name": "Publish to Instagram",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 3,
      "position": [1440, 250],
      "parameters": {
        "method": "POST",
        "url": "=https://graph.facebook.com/v18.0/{{$env.IG_ACCOUNT_ID}}/media",
        "body": {
          "parameters": [
            { "name": "access_token", "value": "={{$env.IG_ACCESS_TOKEN}}" },
            { "name": "caption", "value": "={{ $json.caption }}" },
            { "name": "image_url", "value": "={{ $json.media[0]?.url || '' }}" },
            { "name": "media_type", "value": "={{ $json.post_type === 'reel' ? 'REELS' : 'IMAGE' }}" }
          ]
        },
        "options": {}
      }
    },
    {
      "id": "publish-tiktok",
      "name": "Publish to TikTok",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 3,
      "position": [1440, 400],
      "parameters": {
        "method": "POST",
        "url": "https://open.tiktokapis.com/v2/post/publish/video/init/",
        "headers": {
          "parameters": [
            { "name": "Authorization", "value": "=Bearer {{$env.TIKTOK_ACCESS_TOKEN}}" },
            { "name": "Content-Type",  "value": "application/json; charset=UTF-8" }
          ]
        },
        "body": {
          "contentType": "json",
          "body": "={\n  \"post_info\": {\n    \"title\": \"{{ $json.caption.substring(0,150) }}\",\n    \"privacy_level\": \"PUBLIC_TO_EVERYONE\",\n    \"disable_comment\": false\n  },\n  \"source_info\": {\n    \"source\": \"PULL_FROM_URL\",\n    \"video_url\": \"{{ $json.media[0]?.url || '' }}\"\n  }\n}"
        },
        "options": {}
      }
    },
    {
      "id": "collect-results",
      "name": "Collect Result",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1680, 250],
      "parameters": {
        "jsCode": "// Collect result from whichever platform ran\nconst input = $input.first();\nconst prev  = $('split-platforms').first().json;\n\nlet status = 'published';\nlet platformPostId = null;\nlet error = null;\n\ntry {\n  const body = input.json;\n  if (body.error || body.code === 'error') {\n    status = 'failed';\n    error  = JSON.stringify(body.error || body);\n  } else {\n    platformPostId = body.id || body.post_id || body.publish_id || null;\n  }\n} catch(e) {\n  status = 'failed';\n  error  = e.message;\n}\n\nreturn [{ json: {\n  post_id:          prev.post_id,\n  platform_id:      prev.platform_id,\n  platform_name:    prev.platform_name,\n  status:           status,\n  platform_post_id: platformPostId,\n  error:            error,\n  callback_url:     prev.callback_url,\n  api_key:          prev.api_key\n}}];"
      }
    },
    {
      "id": "report-back",
      "name": "Report Back to BabyKawaii",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 3,
      "position": [1900, 250],
      "parameters": {
        "method": "POST",
        "url": "={{ $json.callback_url }}",
        "headers": {
          "parameters": [
            { "name": "X-API-Key", "value": "={{ $json.api_key }}" },
            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "body": {
          "contentType": "json",
          "body": "={{ JSON.stringify({ post_id: $json.post_id, results: [{ platform_id: $json.platform_id, status: $json.status, platform_post_id: $json.platform_post_id, error: $json.error }] }) }}"
        },
        "options": {}
      }
    }
  ],
  "connections": {
    "Every Minute Check":    { "main": [[{ "node": "Get Scheduled Posts",   "type": "main", "index": 0 }]] },
    "Get Scheduled Posts":   { "main": [[{ "node": "Has Posts?",            "type": "main", "index": 0 }]] },
    "Has Posts?":            { "main": [[{ "node": "Split Each Post",       "type": "main", "index": 0 }], []] },
    "Split Each Post":       { "main": [[{ "node": "Split Each Platform",   "type": "main", "index": 0 }]] },
    "Split Each Platform":   { "main": [[{ "node": "Route by Platform",     "type": "main", "index": 0 }]] },
    "Route by Platform":     {
      "main": [
        [{ "node": "Publish to Facebook",  "type": "main", "index": 0 }],
        [{ "node": "Publish to Instagram", "type": "main", "index": 0 }],
        [{ "node": "Publish to TikTok",    "type": "main", "index": 0 }],
        []
      ]
    },
    "Publish to Facebook":   { "main": [[{ "node": "Collect Result",        "type": "main", "index": 0 }]] },
    "Publish to Instagram":  { "main": [[{ "node": "Collect Result",        "type": "main", "index": 0 }]] },
    "Publish to TikTok":     { "main": [[{ "node": "Collect Result",        "type": "main", "index": 0 }]] },
    "Collect Result":        { "main": [[{ "node": "Report Back to BabyKawaii","type":"main","index":0}]] }
  },
  "settings": {
    "executionOrder": "v1",
    "errorWorkflow": ""
  },
  "meta": {
    "templateCredsSetupCompleted": false,
    "instanceId": "babykawaii"
  },
  "tags": ["babykawaii", "calendar", "autopublish"]
}
