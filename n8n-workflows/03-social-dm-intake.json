          ]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            { "name": "to",       "value": "YOUR_LINE_ADMIN_USER_ID" },
            { "name": "messages", "value": "={{ [{\"type\":\"text\",\"text\":$json.message}] }}" }
          ]
        }
      },
      "id": "line-push-stock",
      "name": "📲 LINE Push — สต็อกต่ำ",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [960, 500]
    },
    {
      "parameters": {
        "url": "https://api.line.me/v2/bot/message/push",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Authorization", "value": "Bearer YOUR_LINE_CHANNEL_ACCESS_TOKEN" },
            { "name": "Content-Type",  "value": "application/json" }
          ]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            { "name": "to",       "value": "YOUR_LINE_ADMIN_USER_ID" },
            { "name": "messages", "value": "={{ [{\"type\":\"text\",\"text\":$json.message}] }}" }
          ]
        }
      },
      "id": "line-push-shipped",
      "name": "📲 LINE Push — จัดส่งแล้ว",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [960, 700]
    }
  ],
